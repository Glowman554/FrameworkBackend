---
import { actions } from 'astro:actions';
import { FakeUserButtons } from './FakeUserEditor';

const users = await Astro.callAction(actions.users.loadAll.orThrow, {});
---

{
    users.map((user) => (
        <div class="section rounded-lg bg-neutral-800 p-2">
            {user.username}
            <div class="flex flex-row">
                <FakeUserButtons user={user} client:load />
            </div>
        </div>
    ))
}
